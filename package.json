{
  "private": true,
  "type": "module",
  "imports": {
    "#commitlint/*": "./src/@commitlint/*.ts",
    "#commitlint-rules": "./src/@commitlint/rules/index.ts",
    "#commitlint-rules/*": "./src/@commitlint/rules/*.ts",
    "#commitlint-rules/body-line-break-punctuation": "./src/@commitlint/rules/body-line-break-punctuation/index.ts"
  },
  "scripts": {
    "build": "vite build",
    "fix": "run-p fix:*",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/format": "^20.5.0",
    "@commitlint/lint": "^20.5.3",
    "@commitlint/message": "^20.4.3",
    "@commitlint/types": "^20.5.0",
    "fp-ts": "^2.16.11",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "parser-ts": "^0.7.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.17",
    "conventional-commits-parser": "^6.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.22"
  }
}
