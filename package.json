{
  "private": true,
  "type": "module",
  "imports": {
    "#commitlint/*": "./src/@commitlint/*.ts",
    "#commitlint-rules": "./src/@commitlint/rules/index.ts",
    "#commitlint-rules/*": "./src/@commitlint/rules/*.ts"
  },
  "scripts": {
    "build": "vite build",
    "fix": "run-p fix:*",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:tsc": "tsc --noEmit",
    "prepare": "effect-language-service patch",
    "test": "vitest run"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/format": "^21.1.0",
    "@commitlint/lint": "^21.1.0",
    "@commitlint/message": "^21.0.1",
    "@commitlint/types": "^21.0.0",
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "effect": "^3.21.3",
    "fp-ts": "^2.16.11",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "parser-ts": "^0.7.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@eslint/js": "^10.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.20.0",
    "conventional-commits-parser": "^7.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-n": "^18.2.1",
    "jiti": "^2.6.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.22"
  }
}
